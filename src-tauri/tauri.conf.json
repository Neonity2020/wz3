{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "智慧卡",
  "version": "0.1.0",
  "identifier": "com.andicode.wisdom-cards",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "智慧卡",
        "width": 1180,
        "height": 780,
        "minWidth": 860,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "infoPlist": "Info.plist"
    }
  }
}
